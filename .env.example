# ==============================================================================
# TRUXIFY — CENTRAL ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to .env and fill in the actual keys for local development.
# ==============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# 1. SUPABASE (Primary Database & API Layer)
# ──────────────────────────────────────────────────────────────────────────────
# Public Supabase URL (from Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous Public Key (Safe to use in client apps)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key-placeholder

# Local backend API base URL used by Flutter apps.
TRUXIFY_API_BASE_URL=http://localhost:5000

# Supabase Service Role Key (SECRET: For backend APIs / admin operations only)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key-placeholder

# Direct PostgreSQL Connection String (For migrations, db seeding, or direct connection)
# Format: postgresql://postgres.[project-id]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=postgresql://postgres.your-project-id:your-db-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Local PostgreSQL/PostGIS via docker-compose
# Use this DATABASE_URL instead when running the backend inside Docker Compose:
# DATABASE_URL=postgresql://postgres:postgrespassword@db:5432/truxify
# Use this host URL for local CLI tools running outside Docker:
# LOCAL_DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5432/truxify
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespassword
POSTGRES_DB=truxify


# ──────────────────────────────────────────────────────────────────────────────
# 1.5 ML ENGINE (API Key for ML Microservice Authentication)
# ──────────────────────────────────────────────────────────────────────────────
# Shared secret used by the API service to authenticate requests to the ML engine.
# Generate a secure random key and set the same value in both services.
ML_API_KEY=<generate-a-secure-random-key>


# ──────────────────────────────────────────────────────────────────────────────
# 2. MONGODB ATLAS (High-Volume Live GPS Pings, Activity logs, ML Training Data)
# ──────────────────────────────────────────────────────────────────────────────
# Full MongoDB connection URI
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.your-subdomain.mongodb.net/?retryWrites=true&w=majority

# Primary database name
MONGODB_DB_NAME=truxify_telemetry


# ──────────────────────────────────────────────────────────────────────────────
# 3. UPSTASH REDIS (User Sessions, API Response Cache, Rate Limiting)
# ──────────────────────────────────────────────────────────────────────────────
# Redis connection details (supports TLS by default in Upstash)
REDIS_URL=rediss://default:your-token@your-instance.upstash.io:6379

# REST API credentials (if querying Redis via HTTP client instead of TCP socket)
REDIS_REST_URL=https://your-instance.upstash.io
REDIS_REST_TOKEN=your-rest-token-placeholder


# ──────────────────────────────────────────────────────────────────────────────
# 4. CLOUDFLARE R2 (Driver Document Uploads, Profile Photos, Invoice PDFs)
# ──────────────────────────────────────────────────────────────────────────────
# R2 Account ID (found on Cloudflare dashboard home)
R2_ACCOUNT_ID=your-cloudflare-account-id

# S3-compatible API Access Credentials for R2
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# Target bucket name
R2_BUCKET_NAME=truxify-assets

# Public domain or custom domain linked to the R2 bucket for asset retrieval
R2_PUBLIC_URL_PREFIX=https://assets.truxify.com


# ──────────────────────────────────────────────────────────────────────────────
# 5. FIREBASE (Authentication Verification & Push Notifications FCM)
# ──────────────────────────────────────────────────────────────────────────────
# Project Identifier
FIREBASE_PROJECT_ID=truxify-auth-prod

# Server side Service Account credentials (JSON stringified or absolute path to key file)
# Example value: /app/config/firebase-service-account.json or direct raw JSON
FIREBASE_SERVICE_ACCOUNT_JSON={"type": "service_account", "project_id": "truxify-auth-prod", "private_key_id": "...", "private_key": "..."}

# Client Web API Key (used for verifying client tokens if needed)
FIREBASE_API_KEY=AIzaSyA-your-firebase-web-api-key

# Firebase Cloud Messaging Sender ID
FIREBASE_MESSAGING_SENDER_ID=123456789012


# ──────────────────────────────────────────────────────────────────────────────
# 6. POLYGON BLOCKCHAIN (Smart Contracts, Reputation Scores, On-chain Receipts)
# ──────────────────────────────────────────────────────────────────────────────
# JSON-RPC Provider node (e.g. Alchemy, Infura, or public RPC)
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your-alchemy-api-key

# Smart Contract deployment addresses
REPUTATION_CONTRACT_ADDRESS=0x1234567890123456789012345678901234567890
ESCROW_CONTRACT_ADDRESS=0x0987654321098765432109876543210987654321

# Wallet Private Key for signing on-chain transactions (Keep this strictly secret!)
# Used by backend relayer for submitting gasless txs for drivers/customers
RELAYER_WALLET_PRIVATE_KEY=0xabcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890


# ──────────────────────────────────────────────────────────────────────────────
# 7. MAPS & ROUTING APIs (Routing calculations, Map tiles, Geocoding backups)
# ──────────────────────────────────────────────────────────────────────────────
# OpenRouteService or Google Maps API key (for calculating distances and duration)
ROUTING_API_KEY=your-routing-api-key


# ──────────────────────────────────────────────────────────────────────────────
# 8. OBSERVABILITY (Logging & Error Tracking)
# ──────────────────────────────────────────────────────────────────────────────
# Minimum log level emitted by the structured logger (pino).
# Supported values: trace | debug | info | warn | error | fatal
# Defaults to "info" when unset.
LOG_LEVEL=info

# Sentry DSN for error tracking and alerting.
# Leave empty to disable Sentry — the application starts normally without it.
SENTRY_DSN=
